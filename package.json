{
  "name": "pi-tmux-window-name",
  "version": "0.4.6",
  "description": "Automatically name tmux windows for pi coding sessions",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "tmux",
    "window-name",
    "session-name"
  ],
  "license": "Apache-2.0",
  "author": "Anton Kuzmenko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/default-anton/pi-tmux-window-name.git"
  },
  "bugs": {
    "url": "https://github.com/default-anton/pi-tmux-window-name/issues"
  },
  "homepage": "https://github.com/default-anton/pi-tmux-window-name#readme",
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --test --experimental-strip-types test/**/*.test.ts",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run pack:check",
    "release:verify-tag": "node scripts/verify-release-tag.mjs",
    "release:notes": "node scripts/changelog-release-notes.mjs",
    "release:gate": "npm run check && npm run test && npm run pack:check"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^25.0.10",
    "typescript": "^5.0.0"
  },
  "files": [
    "extensions/",
    "README.md",
    "LICENSE"
  ]
}
